# Environment — contains API keys, NEVER commit these
.env
*.env
!.env.example        # .env.example is safe to commit (has no real keys)

# Python
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
venv/
env/
.venv/
*.egg-info/
dist/
build/
.eggs/

# Vector store (regenerated by build_index.py)
data/processed/
!data/processed/.gitkeep

# Fine-tuned models and downloaded model cache (large binary files)
models/
data/models/
!data/models/.gitkeep

# Logs
logs/*.log
*.log
!logs/.gitkeep

# OS
.DS_Store
Thumbs.db

# IDE
.vscode/
.idea/
*.swp
*.swo

# GitHub data cache (regenerated by collect_web_data.py)
data/knowledge_base/github.md
data/sources_summary.json

# Jupyter
.ipynb_checkpoints/
*.ipynb
