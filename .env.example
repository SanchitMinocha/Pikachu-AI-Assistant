# SanchitAI Environment Configuration
# ─────────────────────────────────────────────────────────────
# DO NOT commit .env - it contains real keys.
# This file (.env.example) is safe to commit - it has placeholders only.
#
# Setup: cp .env.example .env  then fill in your values.
# ─────────────────────────────────────────────────────────────

# ----- LLM Backend -----
# Options: "ollama" (local), "groq" (cloud fast), "huggingface" (cloud free)
LLM_BACKEND=groq

# ----- Ollama (local LLM - free, no internet needed) -----
# Install: https://ollama.com  |  Start: ollama serve  |  Pull: ollama pull phi3:mini
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=phi3:mini

# ----- Groq API (fast free cloud LLM) -----
# Get free key at: https://console.groq.com
GROQ_API_KEY=<ENTER_YOUR_GROQ_API_KEY_HERE>
GROQ_MODEL=llama-3.1-8b-instant

# ----- Cerebras API (fast free fallback - cloud.cerebras.ai) -----
CEREBRAS_API_KEY=<ENTER_YOUR_CEREBRAS_API_KEY_HERE>
CEREBRAS_MODEL=llama3.1-8b

# ----- OpenRouter API (free models available - openrouter.ai) -----
OPENROUTER_API_KEY=<ENTER_YOUR_OPENROUTER_API_KEY_HERE>
OPENROUTER_MODEL=openai/gpt-oss-20b:free

# ----- HuggingFace API (optional fallback) -----
# Requires a fine-grained token with "Make calls to Inference Providers" permission.
# Create one at: https://huggingface.co/settings/tokens/new?tokenType=fineGrained
# Note: free tier includes $0.10/month in credits.
HF_API_TOKEN=<ENTER_YOUR_HF_FINE_GRAINED_TOKEN_HERE>
HF_MODEL_ID=meta-llama/Llama-3.2-3B-Instruct

# ----- API Security -----
# Generate a random secret: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=<ENTER_A_RANDOM_SECRET_STRING_HERE>
# Optional: if set, /api/rebuild-index requires header X-API-Key: <value>
API_KEY=<ENTER_AN_OPTIONAL_API_KEY_OR_LEAVE_EMPTY>

# ----- Server -----
PORT=5050
FLASK_DEBUG=0
